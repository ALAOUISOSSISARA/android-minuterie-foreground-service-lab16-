<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F0F4F8"
    android:padding="24dp">

    <!-- Carte principale -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/carte_arrondie"
        android:padding="32dp"
        android:elevation="6dp">

        <!-- Titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minuterie"
            android:textSize="22sp"
            android:textColor="#1A237E"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Sous-titre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Service en arrière-plan"
            android:textSize="13sp"
            android:textColor="#9E9E9E"
            android:layout_marginBottom="32dp"/>

        <!-- Affichage du temps -->
        <TextView
            android:id="@+id/tvDuree"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            android:textSize="64sp"
            android:textColor="#1A237E"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="40dp"/>

        <!-- Bouton Démarrer -->
        <Button
            android:id="@+id/btnDemarrer"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="▶  Démarrer"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#3949AB"
            android:layout_marginBottom="12dp"/>

        <!-- Bouton Arrêter -->
        <Button
            android:id="@+id/btnArreter"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="  Arrêter"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E53935"
            android:layout_marginBottom="12dp"/>

        <!-- Bouton Réinitialiser -->
        <Button
            android:id="@+id/btnReinit"
            android:layout_width="220dp"
            android:layout_height="52dp"
            android:text="↺  Réinitialiser"
            android:textSize="16sp"
            android:textColor="#3949AB"
            android:backgroundTint="#E8EAF6"/>

    </LinearLayout>

</LinearLayout>